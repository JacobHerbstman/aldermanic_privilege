# #################################################
# ## Generic gitignore for a task-based workflow
# #################################################

# --- System & Editor Files ---
.DS_Store
.Rhistory
__pycache__/
node_modules/

# --- Log files ---
*.log
slurmlogs/

# --- Raw & Intermediate Data ---
# Ignore raw data by default, except static boundaries required for replication.
data_raw/*
!data_raw/Chicago_Wards_1998.geojson
!data_raw/Boundaries_-_Zoning_Districts_20250910.geojson
!data_raw/Wards_2014.geojson
!data_raw/Wards_2015.geojson
!data_raw/Wards_2024.geojson

# Ignore the contents of ALL input, output, and temp folders
# for every task. The trailing slash is important.
tasks/*/input/
tasks/*/output/
tasks/*/temp/

# --- User-specific files ---
# (Add any local configuration files here if needed)
AGENTS.md
CLAUDE.md
.claude/

# --- Secrets ---
# Ignore file containing API keys and other secrets
.Renviron


# Archive task folders (two levels deep)
tasks/_deprecated/
tasks/archive/
tasks/archive/*/input/
tasks/archive/*/output/
tasks/archive/*/temp/
tasks/audits/*/input/
tasks/audits/*/output/
tasks/audits/*/temp/

# Exception: track the task flow graph for README
!tasks/symlink_graph/output/
tasks/symlink_graph/output/graph.txt
!tasks/symlink_graph/output/task_flow.png

# ================== ADDITIONS ==================

# Paper: ignore generated build artifacts, keep paper source tracked
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fff
paper/*.fls
paper/*.out
paper/*.pdf
paper/*.synctex.gz
paper/*.ttt
short_paper/*.aux
short_paper/*.bbl
short_paper/*.blg
short_paper/*.fdb_latexmk
short_paper/*.fff
short_paper/*.fls
short_paper/*.log
short_paper/*.out
short_paper/*.pdf
short_paper/*.synctex.gz
short_paper/*.ttt

# Slides: ignore generated build artifacts, keep slide source tracked
slides/*.aux
slides/*.bbl
slides/*.blg
slides/*.fdb_latexmk
slides/*.fls
slides/*.log
slides/*.nav
slides/*.out
slides/*.pdf
slides/*.synctex.gz
slides/*.snm
slides/*.toc
slides/images/*
slides/figures/*
!slides/images/home_price_growth.png
!slides/images/rent_growth_headline.png
!slides/figures/pipeline_tikz.tex
mansueto_slides/*.aux
mansueto_slides/*.bbl
mansueto_slides/*.blg
mansueto_slides/*.fdb_latexmk
mansueto_slides/*.fls
mansueto_slides/*.log
mansueto_slides/*.nav
mansueto_slides/*.out
mansueto_slides/*.pdf
mansueto_slides/*.snm
mansueto_slides/*.toc

tmp/

# Local-only verification scratch
tasks/audits/run_event_study_rental_guangbin_wardblock/
tasks/create_event_study_permit_data/code/manual_permit_block_review.csv

# Ignore auto-generated R graphics in any code/ folder
Rplots.pdf
**/code/Rplots.pdf
